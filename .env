# Runtime
ENVIRONMENT=production
LOG_LEVEL=info
APP_NAME=NewStoreAgent
DRY_RUN=true

# Webhook security
# Configure the same value in Brevo webhook custom header X-Webhook-Token.
BREVO_WEBHOOK_SECRET=replace-with-a-random-secret
ADMIN_API_TOKEN=replace-with-a-random-admin-token

# OpenAI
# Do NOT commit real keys. Configure these in Vercel Project Settings > Environment Variables.
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-5.5
OPENAI_AGENT_NAME=NewStoreAgent

# Database
# Prefer pooled URL on serverless. Do NOT commit real database passwords.
DATABASE_URL=postgres://postgres.mgwvavsjxzwflibcjzhd:CtPrJ5nOpomcjuJV@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
AUTO_CREATE_TABLES=false

# Brevo outbound adapter
# Keep DRY_RUN=true until the inbound pipeline is confirmed.
# Set BREVO_SEND_URL only after confirming the correct Brevo endpoint for your account/product.
BREVO_API_KEY=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
BREVO_SEND_URL=https://api.brevo.com/v3
BREVO_SENDER_NUMBER=+55 21 97432 0164
BREVO_REPLY_MODE=dry_run

